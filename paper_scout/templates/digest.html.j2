<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Scout Digest</title>
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
        line-height: 1.5;
        color: #222;
        margin: 0;
        padding: 0;
        background: #f8fafc;
      }

      .container {
        max-width: 860px;
        margin: 0 auto;
        padding: 24px;
        background: #ffffff;
      }

      h1 {
        font-size: 24px;
        margin-top: 0;
      }

      h2 {
        margin-top: 28px;
        font-size: 20px;
      }

      h3 {
        margin: 0 0 8px;
        font-size: 18px;
      }

      .meta {
        margin: 8px 0 24px;
        color: #555;
      }

      .paper {
        border-top: 1px solid #e5e7eb;
        padding: 18px 0;
      }

      .paper:first-of-type {
        border-top: none;
      }

      .score {
        margin: 4px 0 8px;
        color: #111827;
      }

      .dim {
        color: #4b5563;
        font-size: 14px;
        margin: 2px 0;
      }

      .section-label {
        margin: 10px 0 4px;
        font-weight: 600;
      }

      ul {
        margin-top: 6px;
      }

      .noteworthy-list {
        padding-left: 18px;
      }

      .noteworthy-list li {
        margin-bottom: 8px;
      }

      a {
        color: #2563eb;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      .footer {
        margin-top: 24px;
        font-size: 12px;
        color: #6b7280;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>📄 Scout Digest — {{ date_display }}</h1>
      <div class="meta">
        <strong>{{ selected_count }}</strong> papers surfaced out of {{ total_reviewed }} reviewed
        <br />
        Threshold: ≥{{ threshold | fmt_score }}
      </div>

      {% if selected_count == 0 %}
      <p>No papers met your criteria in this run.</p>
      {% else %}
      {% if deep_reads %}
      <h2>🔍 Deep Reads</h2>

      {% for item in deep_read_items %}
      {% set entry = item.entry %}
      <div class="paper">
        <h3>{{ loop.index }}. <a href="{{ entry.paper.url }}">{{ entry.paper.title }}</a></h3>

        <p class="score">
          <strong>Score:</strong> {{ entry.relevance_score | fmt_score }}/10
          &nbsp;·&nbsp;
          <strong>Novelty:</strong> {{ entry.novelty_signal }}
          {% if entry.paper.source_label %}
          &nbsp;·&nbsp;
          <strong>Source:</strong> {{ entry.paper.source_label }}
          {% endif %}
          {% if entry.watchlist_match %}
          &nbsp;·&nbsp;
          <strong>Watchlist:</strong> {{ entry.watchlist_match }}
          {% endif %}
        </p>
        {% if entry.ranking_score is not none and (entry.ranking_score - entry.relevance_score)|abs >= 0.1 %}
        <p class="dim"><strong>Personal fit:</strong> {{ entry.ranking_score | fmt_score }}/10</p>
        {% endif %}

        <p class="dim"><strong>Authors:</strong> {{ entry.paper.authors | join(", ") }}</p>
        <p class="dim"><strong>Categories:</strong> {{ entry.paper.categories | join(", ") }}</p>

        <p><strong>Triage:</strong> {{ entry.breakdown.triage }}</p>

        <p class="section-label">TL;DR</p>
        <ul>
          {% for bullet in entry.breakdown.tldr %}
          <li>{{ bullet }}</li>
          {% endfor %}
        </ul>

        <p class="section-label">Motivation</p>
        <p>{{ entry.breakdown.motivation }}</p>

        <p class="section-label">Hypothesis</p>
        <p>{{ entry.breakdown.hypothesis }}</p>

        <p class="section-label">Methodology</p>
        <p>{{ entry.breakdown.methodology }}</p>

        <p class="section-label">Results</p>
        <p>{{ entry.breakdown.results }}</p>

        <p class="section-label">Interpretation</p>
        <p>{{ entry.breakdown.interpretation }}</p>

        <p class="section-label">Context</p>
        <p>{{ entry.breakdown.context }}</p>

        <p class="section-label">Limitations</p>
        <p>{{ entry.breakdown.limitations }}</p>

        <p class="section-label">Why it matters to you</p>
        <p>{{ entry.breakdown.relevance }}</p>

        <p>
          <a href="{{ entry.paper.pdf_url }}">📄 PDF</a>
          &nbsp;·&nbsp;
          <a href="{{ entry.paper.url }}">🔗 Abstract</a>
          {% if item.feedback %}
          &nbsp;·&nbsp;
          <a href="{{ item.feedback.upvote_url }}">👍 Interesting</a>
          &nbsp;·&nbsp;
          <a href="{{ item.feedback.downvote_url }}">👎 Not Interesting</a>
          {% endif %}
        </p>
      </div>
      {% endfor %}
      {% endif %}

      {% if noteworthy_entries %}
      <h2>Also Noteworthy</h2>
      <ul class="noteworthy-list">
        {% for item in noteworthy_items %}
        {% set entry = item.entry %}
        <li>
          <a href="{{ entry.paper.url }}"><strong>{{ entry.paper.title }}</strong></a>
          — {{ entry.relevance_score | fmt_score }}/10
          {% if entry.paper.source_label %}
          · Source: {{ entry.paper.source_label }}
          {% endif %}
          {% if entry.watchlist_match %}
          · Watchlist: {{ entry.watchlist_match }}
          {% endif %}
          {% if entry.ranking_score is not none and (entry.ranking_score - entry.relevance_score)|abs >= 0.1 %}
          · Personal fit: {{ entry.ranking_score | fmt_score }}/10
          {% endif %}
          . {{ entry.summary }}
          (<a href="{{ entry.paper.pdf_url }}">PDF</a>)
          {% if item.feedback %}
          · <a href="{{ item.feedback.upvote_url }}">👍 Interesting</a>
          · <a href="{{ item.feedback.downvote_url }}">👎 Not Interesting</a>
          {% endif %}
        </li>
        {% endfor %}
      </ul>
      {% endif %}
      {% endif %}

      <div class="footer">
        Generated by Scout · This digest cost ${{ "%.2f"|format(run_cost_usd) }} · Scout total to date: ${{ "%.2f"|format(total_cost_usd) }}
      </div>
    </div>
  </body>
</html>
