<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Scout Digest</title>
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
        line-height: 1.5;
        color: #222;
        margin: 0;
        padding: 0;
        background: #f8fafc;
      }

      .container {
        max-width: 760px;
        margin: 0 auto;
        padding: 24px;
        background: #ffffff;
      }

      h1 {
        font-size: 24px;
        margin-top: 0;
      }

      .meta {
        margin: 8px 0 24px;
        color: #555;
      }

      .paper {
        border-top: 1px solid #e5e7eb;
        padding: 18px 0;
      }

      .paper:first-of-type {
        border-top: none;
      }

      .title {
        font-size: 18px;
        font-weight: 600;
        margin: 0 0 6px;
      }

      .score {
        margin: 4px 0 8px;
        color: #111827;
      }

      .dim {
        color: #4b5563;
        font-size: 14px;
        margin: 2px 0;
      }

      .summary {
        margin: 10px 0 10px;
      }

      a {
        color: #2563eb;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      .footer {
        margin-top: 24px;
        font-size: 12px;
        color: #6b7280;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>📄 Scout Digest — {{ date_display }}</h1>
      <div class="meta">
        <strong>{{ selected_count }}</strong> papers scored ≥{{ threshold | fmt_score }} out of {{ total_reviewed }} reviewed
      </div>

      {% if selected_count == 0 %}
      <p>No papers met your threshold today.</p>
      {% else %}
      {% for entry in entries %}
      <div class="paper">
        <p class="title">
          {{ loop.index }}.
          <a href="{{ entry.paper.url }}">{{ entry.paper.title }}</a>
        </p>

        <p class="score">
          <strong>Score:</strong> {{ entry.relevance_score | fmt_score }}/10
          &nbsp;·&nbsp;
          <strong>Novelty:</strong> {{ entry.novelty_signal }}
        </p>

        <p class="dim"><strong>Authors:</strong> {{ entry.paper.authors | join(", ") }}</p>
        <p class="dim"><strong>Categories:</strong> {{ entry.paper.categories | join(", ") }}</p>

        <p class="summary">{{ entry.summary }}</p>

        <p>
          <a href="{{ entry.paper.pdf_url }}">📄 PDF</a>
          &nbsp;·&nbsp;
          <a href="{{ entry.paper.url }}">🔗 Abstract</a>
        </p>
      </div>
      {% endfor %}
      {% endif %}

      <div class="footer">
        Generated by Scout.
      </div>
    </div>
  </body>
</html>